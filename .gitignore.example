# FIR local virtualenv
.venv-fir/

# Python build/cache artifacts
__pycache__/
*.py[cod]
*.egg-info/

# Local overlay/package archives created during iteration
Novel_GRAND_*overlay.zip
Novel_GRAND_*package.zip
Novel_GRAND_*full*.zip

# Transient smoke / probe logs
probe_outputs/check_tags_package_*.log
outputs/slurm_tags_*.out
outputs/slurm_tags_*.err

# Large generated artifacts that are not needed on GitHub
outputs/_effective_code_cache/
outputs/*/probe/shards/
outputs/*/train/shards/
outputs/*/eval/shards/
outputs/*/eval/sampled_failures/
outputs/*/models/*.pt
outputs/*/models/*.pth
